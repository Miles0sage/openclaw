# ═══════════════════════════════════════════════════════════════
# OpenClaw v4.1 — Environment Configuration
# Copy to .env and fill in your values. Never commit .env!
# ═══════════════════════════════════════════════════════════════

# ─── CORE ───
NODE_ENV=production
PORT=18789
LOG_LEVEL=info
OPENCLAW_CONFIG=/path/to/openclaw/config.json
GATEWAY_AUTH_TOKEN=your_gateway_auth_token

# ─── AI PROVIDERS ───
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxx
OLLAMA_HOST=http://localhost:11434

# ─── SLACK ───
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxxxxxxxxxxx
SLACK_APP_TOKEN=xapp-xxxxxxxxxxxxxxxxxxxxx
SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxxxxxxx
SLACK_REPORT_CHANNEL=C0XXXXXXXXXXX
SLACK_WEBHOOK_URL=http://localhost:18789/webhook/slack-test

# ─── TELEGRAM ───
TELEGRAM_BOT_TOKEN=1234567890:ABCxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_USER_ID=1234567890

# ─── DISCORD (optional) ───
# DISCORD_BOT_TOKEN=xxxxxxxxxxxxxxxxxxxxx

# ─── TWILIO (SMS + WhatsApp) ───
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+1XXXXXXXXXX
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ─── VOICE (ElevenLabs + Vapi) ───
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxx
VAPI_API_KEY=xxxxxxxxxxxxxxxxxxxxx
VAPI_PHONE_NUMBER_ID=xxxxxxxxxxxxxxxxxxxxx

# ─── SUPABASE ───
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxx

# ─── CACHE (Upstash Redis) ───
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxx

# ─── TRADING / PREDICTION MARKETS (optional) ───
KALSHI_API_KEY_ID=xxxxxxxxxxxxxxxxxxxxx
KALSHI_PRIVATE_KEY_PATH=/path/to/kalshi_private.pem
ODDS_API_KEY=xxxxxxxxxxxxxxxxxxxxx

# ─── BOT TOKENS (optional) ───
CODERCLAW_BOT_TOKEN=xxxxxxxxxxxxxxxxxxxxx
